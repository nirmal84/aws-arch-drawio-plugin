{
  "name": "aws-arch-drawio-plugin",
  "version": "0.1.0",
  "description": "Claude Code plugin: generate Draw.io architecture diagrams from AWS IaC code with official AWS icons",
  "author": "Nirmal",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "aws-arch-drawio": "dist/index.js" },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "glob": "^10.3.10",
    "zod": "^3.22.4",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.5",
    "@types/js-yaml": "^4.0.9",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
